ui_init() {
  if [ "${USE_COLORS:-1}" = "1" ]; then
    C_TITLE="$(printf '\033[1;36m')"
    C_OK="$(printf '\033[1;32m')"
    C_WARN="$(printf '\033[1;33m')"
    C_ERROR="$(printf '\033[1;31m')"
    C_RESET="$(printf '\033[0m')"
